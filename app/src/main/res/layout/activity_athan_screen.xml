<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B3A2D"
    android:layoutDirection="rtl">

    <!-- أيقونة المسجد -->
    <ImageView
        android:id="@+id/iv_mosque_top"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@drawable/ic_mosque"
        android:tint="#C9A84C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="56dp" />

    <!-- صورة الوالد -->
    <ImageView
        android:id="@+id/iv_father_photo"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_mosque"
        android:scaleType="centerCrop"
        android:background="@drawable/circle_gold_border"
        android:padding="3dp"
        app:layout_constraintTop_toBottomOf="@id/iv_mosque_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- اسم الصلاة -->
    <TextView
        android:id="@+id/tv_prayer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الفجر"
        android:textColor="#C9A84C"
        android:textSize="52sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/iv_father_photo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- نص الأذان -->
    <TextView
        android:id="@+id/tv_athan_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="حان وقت الصلاة"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tv_prayer_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- اسم التطبيق / إهداء للوالد -->
    <TextView
        android:id="@+id/tv_father_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="إهداء إلى روح والدي\nمحمد عبد العظيم الطويل"
        android:textColor="#8BAF8B"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_athan_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- زر الإيقاف -->
    <Button
        android:id="@+id/btn_stop_athan"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="إيقاف الأذان"
        android:textSize="18sp"
        android:backgroundTint="#C9A84C"
        android:textColor="#1B3A2D"
        android:textStyle="bold"
        android:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
